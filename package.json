{
  "name": "agentic-debug-mode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "debug-mode": "dist/debug-mode"
  },
  "scripts": {
    "build": "bun run build:native && bun run build:binary",
    "build:native": "bun scripts/build-native.ts",
    "build:binary": "bun scripts/build-binary.ts",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "napi": {
    "binaryName": "agentic-debug-mode"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@napi-rs/cli": "^3.7.3",
    "@types/bun": "^1.3.14",
    "typescript": "^7.0.2"
  }
}
